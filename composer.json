{
  "name": "andreyukdev/mileena-crm-skeleton",
  "description": "CRM skeleton based on Mileena framework",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Artem Andreyuk"
    }
  ],
  "require": {
    "php": ">=8.4",
    "andreyukdev/mileena": "^1.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^13.0"
  },
  "autoload": {
    "psr-4": {
      "Mileena\\CrmSkeleton\\": "src/"
    }
  },
  "config": {
    "sort-packages": true
  }
}